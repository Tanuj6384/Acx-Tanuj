Public Function AmountInWords(ByVal Amount As Decimal, ByVal CurrCode As String) As String
    If CurrCode = "INR" OR CurrCode = "" Then
        Return RupeesToWord(Amount, "Rupees", "Paisa")
    Else
        Return CurrCode & " " & CStr(Amount) & " Only"
    End If
End Function
